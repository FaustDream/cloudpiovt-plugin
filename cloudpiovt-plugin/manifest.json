{
  "manifest_version": 3,
  "name": "云枢开发助手",
  "short_name": "云枢开发助手",
  "description": "抓取云枢在线开发页面数据，和本地代码文件双向同步，并生成 README.MD 说明文件。",
  "version": "2.0.0",
  "key": "",
  "icons": {
    "16": "assets/ztdh-logo.png",
    "32": "assets/ztdh-logo.png",
    "48": "assets/ztdh-logo.png",
    "128": "assets/ztdh-logo.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "nativeMessaging"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "云枢开发助手",
    "default_icon": {
      "16": "assets/ztdh-logo.png",
      "32": "assets/ztdh-logo.png",
      "48": "assets/ztdh-logo.png",
      "128": "assets/ztdh-logo.png"
    },
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
