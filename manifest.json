{
  "manifest_version": 3,
  "name": "开发助手",
  "short_name": "开发助手",
  "description": "为云枢和氚云开发页面提供本地代码抓取、回写和目录协作能力。",
  "version": "1.8.0",
  "author": "凌致",
  "key": "",
  "icons": {
    "16": "assets/icons/extension/icon-16.png",
    "48": "assets/icons/extension/icon-48.png",
    "128": "assets/icons/extension/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "nativeMessaging",
    "alarms"
  ],
  "host_permissions": [
    "https://raw.githubusercontent.com/FaustDream/chrome-plugin/*"
  ],
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "开发助手",
    "default_icon": {
      "16": "assets/icons/extension/icon-16.png",
      "48": "assets/icons/extension/icon-48.png",
      "128": "assets/icons/extension/icon-128.png"
    },
    "default_popup": "src/pages/popup.html"
  },
  "options_page": "src/pages/options.html"
}
